# ===== Required =====
JWT_SECRET=change-me-to-a-long-random-string
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=ChangeThisPasswordNow

# MongoDB (chat history persistence)
MONGO_URL=mongodb://localhost:27017
DB_NAME=genie_sidekick

# CORS (your frontend origin, comma-separated for multiple)
CORS_ORIGINS=http://localhost:5173

# ===== LLM providers — set AT LEAST ONE =====

# Cerebras Cloud (fast, cheap, mild censorship)
# https://cloud.cerebras.ai
CEREBRAS_API_KEY=
CEREBRAS_MODEL=qwen-3-235b-a22b-instruct-2507

# Venice.ai (uncensored by design, requires Venice Pro ~$20/mo)
# https://venice.ai/settings/api
VENICE_API_KEY=
VENICE_MODEL=venice-uncensored

# Ollama (local, fully uncensored if you pick the right model)
# OLLAMA_BASE_URL points to a reachable Ollama server (LAN IP, tunnel, etc.)
OLLAMA_BASE_URL=
OLLAMA_MODEL=dolphin-mixtral:8x7b
